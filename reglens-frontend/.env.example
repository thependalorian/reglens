# RegLens frontend — self-hosted (no managed CopilotKit Intelligence).
# The CopilotKit runtime route brokers to the FastAPI AG-UI endpoint at AGENT_URL/agui.
AGENT_URL=http://localhost:8058
BACKEND_URL=http://localhost:8058

# Bearer token forwarded to the backend (empty = backend dev mode). Never exposed to the browser.
REGLENS_API_TOKEN=
