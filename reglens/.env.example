# ============================================================
# RegLens — copy to .env, never commit real secrets
# ============================================================

# LLM
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_CHOICE=gpt-4o-mini
LLM_CHOICE_CAPABLE=gpt-4o

# Embeddings
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMENSION=1536

# Neon Postgres — one DATABASE_URL for corpus, findings, and the
# LangGraph HITL checkpointer. Use the pooled connection string from
# the Neon console (code sets statement_cache_size=0 for the pooler).
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-ENDPOINT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# API auth — app-level bearer token (Neon has no auth service).
# Empty REGLENS_API_TOKEN = dev mode (fixed dev identity below).
# Set a strong token in production; clients send it as Bearer <token>.
REGLENS_API_TOKEN=
REGLENS_USER_ID=00000000-0000-0000-0000-000000000001
REGLENS_USER_EMAIL=dev@reglens.local

# Rate limiting (per user, in-memory sliding window)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# Document Parsing
# ============================================================
# Hierarchy: LlamaParse (if key set) -> Docling (local) -> read_text
#
# Docling runs locally — no key needed. Install: pip install docling
# Handles PDF, DOCX, PPTX, XLSX, HTML with AI layout understanding.
# Recommended parser for SADC/African regulatory documents; no corpus
# data leaves the environment (relevant for central bank deployments).
DOCLING_ENABLED=true

# LlamaParse — optional cloud upgrade (best quality, scanned PDFs).
# Get free credits: https://cloud.llamaindex.ai/ (10k pages/month)
# If set, LlamaParse runs first; Docling is the fallback.
# Leave blank to use Docling only.
LLAMA_CLOUD_API_KEY=

# FastAPI
APP_PORT=8058
APP_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Ollama local override (set these to use local models)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_CHOICE=qwen2.5:7b
# EMBEDDING_MODEL=nomic-embed-text
# VECTOR_DIMENSION=768

# LangGraph PostgresSaver for time-travel support (ag_ui_langgraph)
# Uses the same DATABASE_URL as the application pool
# Set to "false" to use MemorySaver (dev only — time-travel won't persist)
USE_POSTGRES_CHECKPOINTER=true
