# RegLens monorepo — backend (reglens/) + frontend (reglens-frontend/)
# Per-subproject .gitignore files also apply; this is the shared baseline.

# Secrets — never commit
.env
.env.*
!.env.example
*.pem
*.key

# Python (backend)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Node / Next.js (frontend)
node_modules/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
next-env.d.ts

# Tooling / agents
.agents/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
